{
  "name": "cocoa-rn",
  "version": "1.0.0",
  "description": "An opinionated toast component for React Native. Spring physics and a minimal API — beautiful by default.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "import": "./lib/module/index.js",
      "require": "./lib/commonjs/index.js",
      "types": "./lib/typescript/index.d.ts"
    }
  },
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "build": "bob build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "del-cli lib",
    "test": "jest",
    "prepare": "bob build"
  },
  "keywords": [
    "react-native",
    "toast",
    "notification",
    "snackbar",
    "spring",
    "animation",
    "cocoa",
    "expo"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/crunux/cocoa-rn.git"
  },
  "author": "Joan Cruz <crunux@proton.me>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/crunux/cocoa-rn/issues"
  },
  "homepage": "https://github.com/crunux/cocoa-rn#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.70.0"
  },
  "devDependencies": {
    "@react-native/eslint-config": "^0.73.1",
    "@types/jest": "^29.5.5",
    "@types/react": "~19.1.0",
    "@types/react-native": "~0.73.0",
    "del-cli": "^5.1.0",
    "eslint": "^9.25.0",
    "jest": "^29.7.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-builder-bob": "^0.23.2",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ]
}